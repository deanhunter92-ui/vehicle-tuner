{
  "expo": {
    "name": "Vehicle Tuner",
    "slug": "vehicle-tuner",
    "version": "1.0.0",
    "android": {
      "package": "com.beagally.cartuner"
    },
    "extra": {
      "eas": {
        "projectId": "a78760d1-4c01-41bb-9bf4-001b3634ab76"
      }
    }
  }
}      
"edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
